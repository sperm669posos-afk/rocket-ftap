-- ══════════════════════════════════════
--  FIND MISSILE  (ищем везде)
-- ══════════════════════════════════════
local function findMissile()
    -- 1. В workspace среди потомков (уже заспавненная)
    for _, v in ipairs(Workspace:GetDescendants()) do
        if v.Name == CFG.missileName and v:IsA("BasePart") then
            return v
        end
        -- иногда это Model у которой PrimaryPart
        if v.Name == CFG.missileName and v:IsA("Model") then
            return v.PrimaryPart or v:FindFirstChildWhichIsA("BasePart")
        end
    end

    -- 2. В рюкзаке (Tool)
    for _, tool in ipairs(lp.Backpack:GetChildren()) do
        if tool.Name:lower():find("missile") or tool.Name:lower():find("missle") then
            return tool:FindFirstChildWhichIsA("BasePart") or tool.PrimaryPart
        end
    end

    -- 3. В текущем character (Tool экипирован)
    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") and (tool.Name:lower():find("missile") or tool.Name:lower():find("missle")) then
            return tool:FindFirstChildWhichIsA("BasePart") or tool.PrimaryPart
        end
    end

    return nil
end

-- ══════════════════════════════════════
--  SPAWN  (бесконечный, без лимита)
-- ══════════════════════════════════════
local function spawnMissile()
    -- каждый раз ищем заново — без кеша
    missile = findMissile()
    if missile and missile.Parent then
        notify("☄️  Missile found — ready!")
        return
    end

    -- пробуем RemoteEvent спавна игры
    local function tryRemote(parent)
        if not parent then return false end
        for _, re in ipairs(parent:GetDescendants()) do
            if re:IsA("RemoteEvent") then
                local n = re.Name:lower()
                if n:find("spawn") or n:find("toy") or n:find("item") or n:find("missile") or n:find("missle") then
                    pcall(function() re:FireServer(CFG.missileName) end)
                    pcall(function() re:FireServer() end)
                end
            end
        end
        return false
    end

    tryRemote(ReplicatedStorage)
    tryRemote(Workspace)

    task.wait(1.2)
    missile = findMissile()

    if missile and missile.Parent then
        notify("☄️  Missile spawned!")
        return
    end

    -- Fallback: визуальная ракета-заглушка (красная, как настоящая)
    local model = Instance.new("Model")
    model.Name = CFG.missileName

    local body = Instance.new("Part")
    body.Name = "Body"
    body.Size = Vector3.new(0.8, 0.8, 5)
    body.BrickColor = BrickColor.new("Bright red")
    body.Material = Enum.Material.SmoothPlastic
    body.CFrame = root.CFrame * CFrame.new(0, 2, -7)
    body.Parent = model

    local nose = Instance.new("SpecialMesh", body)
    nose.MeshType = Enum.MeshType.FileMesh
    nose.MeshId = "rbxassetid://9064951980"
    nose.Scale = Vector3.new(0.4, 0.4, 2)

    local fin1 = Instance.new("Part")
    fin1.Size = Vector3.new(0.1, 1.2, 0.8)
    fin1.BrickColor = BrickColor.new("Bright red")
    fin1.Material = Enum.Material.SmoothPlastic
    fin1.CFrame = body.CFrame * CFrame.new(0, -0.6, 1.8)
    fin1.Parent = model

    local fin2 = fin1:Clone()
    fin2.CFrame = body.CFrame * CFrame.new(0.6, 0, 1.8)
    fin2.Size = Vector3.new(1.2, 0.1, 0.8)
    fin2.Parent = model

    local weld1 = Instance.new("WeldConstraint")
    weld1.Part0 = body
    weld1.Part1 = fin1
    weld1.Parent = model

    local weld2 = Instance.new("WeldConstraint")
    weld2.Part0 = body
    weld2.Part1 = fin2
    weld2.Parent = model

    model.PrimaryPart = body
    model.Parent = Workspace
    missile = body
    notify("☄️  Missile ready (local)!")
end

-- ══════════════════════════════════════
--  FPV
-- ══════════════════════════════════════
local function startFPV()
    if not missile or not missile.Parent then return end
    Camera.CameraType = Enum.CameraType.Scriptable
    Camera.FieldOfView = 75
    fpvConn = RunService.RenderStepped:Connect(function()
        if missile and missile.Parent then
            Camera.CFrame = missile.CFrame * CFrame.new(0, 0.2, -2.2)
        end
    end)
end

local function stopFPV()
    if fpvConn then fpvConn:Disconnect() fpvConn = nil end
    Camera.CameraType = Enum.CameraType.Custom
    Camera.FieldOfView = origFOV
end

-- ══════════════════════════════════════
--  FLIGHT
-- ══════════════════════════════════════
local function stopFlight()
    flying = false
    if gyroConn then gyroConn:Disconnect() gyroConn = nil end
    if vel  and vel.Parent  then vel:Destroy()  vel  = nil end
    if gyro and gyro.Parent then gyro:Destroy() gyro = nil end
    stopFPV()
    notify("💥  Impact!")
end

local function launchMissile()
    if not missile or not missile.Parent then
        notify("⚠  Spawn missile first!")
        return
    end
    if flying then
        stopFlight()
        return
    end

    -- убираем Anchored если есть
    missile.Anchored = false

    flying = true

    vel = Instance.new("BodyVelocity")
    vel.MaxForce = Vector3.new(1e6, 1e6, 1e6)
    vel.Velocity  = missile.CFrame.LookVector * CFG.speed
    vel.Parent    = missile

    gyro = Instance.new("BodyGyro")
    gyro.MaxTorque = Vector3.new(4e5, 4e5, 4e5)
    gyro.P         = 5000
    gyro.D         = 300
    gyro.CFrame    = missile.CFrame
    gyro.Parent    = missile

    startFPV()
    notify("🚀  Launched! W/A/S/D to steer")

    gyroConn = RunService.Heartbeat:Connect(function(dt)
        if not missile or not missile.Parent then
            stopFlight()
            return
        end

        local up    = UserInputService:IsKeyDown(Enum.KeyCode.W)
        local down  = UserInputService:IsKeyDown(Enum.KeyCode.S)
        local left  = UserInputService:IsKeyDown(Enum.KeyCode.A)
        local right = UserInputService:IsKeyDown(Enum.KeyCode.D)

        local dPitch = 0
        local dYaw   = 0
        if up    then dPitch = -CFG.turnSpeed * dt end
        if down  then dPitch =  CFG.turnSpeed * dt end
        if left  then dYaw   =  CFG.turnSpeed * dt end
        if right then dYaw   = -CFG.turnSpeed * dt end

        gyro.CFrame = gyro.CFrame * CFrame.Angles(dPitch, dYaw, 0)
        vel.Velocity = gyro.CFrame.LookVector * CFG.speed
    end)
end

-- ══════════════════════════════════════
--  MOBILE SWIPE
-- ══════════════════════════════════════
UserInputService.TouchMoved:Connect(function(touch)
    if not flying or not missile or not missile.Parent then return end
    local dx =  touch.Delta.X / 25
    local dy =  touch.Delta.Y / 25
    if gyro then
        gyro.CFrame = gyro.CFrame * CFrame.Angles(-dy * 0.06, -dx * 0.06, 0)
    end
end)

