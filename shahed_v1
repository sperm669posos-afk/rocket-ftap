local function startFlight(target)
    if flying then return end
    rocket = target
    if not rocket then return end

    local root = rocket:IsA("Model") and rocket.PrimaryPart or rocket
    if not root then return end

    camera.CameraType = Enum.CameraType.Scriptable
    flying = true

    bodyVel = Instance.new("BodyVelocity")
    bodyVel.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bodyVel.Velocity = Vector3.zero
    bodyVel.Parent = root

    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bodyGyro.P = 1e5
    bodyGyro.Parent = root

    connections[#connections+1] = RunService.RenderStepped:Connect(function(dt)
        if not flying or not rocket or not rocket.Parent then
            stopFlight()
            return
        end
        local r = rocket:IsA("Model") and rocket.PrimaryPart or rocket
        if not r then return end

        local fwd = camera.CFrame.LookVector
        local right = camera.CFrame.RightVector
        local up = Vector3.new(0, 1, 0)

        local move = Vector3.zero
        if keysDown[Enum.KeyCode.W] or keysDown[Enum.KeyCode.Up] then move = move + fwd end
        if keysDown[Enum.KeyCode.S] or keysDown[Enum.KeyCode.Down] then move = move - fwd end
        if keysDown[Enum.KeyCode.A] or keysDown[Enum.KeyCode.Left] then move = move - right end
        if keysDown[Enum.KeyCode.D] or keysDown[Enum.KeyCode.Right] then move = move + right end
        if keysDown[Enum.KeyCode.Space] then move = move + up end
        if keysDown[Enum.KeyCode.LeftShift] then move = move - up end

        if move.Magnitude > 0 then
            move = move.Unit * math.clamp(flightSpeed, 10, MAX_SPEED)
        end
        bodyVel.Velocity = move
        if move.Magnitude > 0 then
            bodyGyro.CFrame = CFrame.lookAt(r.Position, r.Position + move)
        end

        local nose = r.CFrame * CFrame.new(0, 1.5, -3)
        camera.CFrame = nose
    end)

    if LaunchRemote then
        pcall(function() LaunchRemote:FireServer(rocket) end)
    end
end

function stopFlight()
    flying = false
    camera.CameraType = Enum.CameraType.Custom
    if bodyVel then bodyVel:Destroy() bodyVel = nil end
    if bodyGyro then bodyGyro:Destroy() bodyGyro = nil end
    for _, c in ipairs(connections) do c:Disconnect() end
    connections = {}
    rocket = nil
end

