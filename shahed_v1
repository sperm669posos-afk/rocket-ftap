local function findRemote(names)
    for _, name in ipairs(names) do
        local r = ReplicatedStorage:FindFirstChild(name, true)
        if r and r:IsA("RemoteEvent") then return r end
    end
    for _, obj in ipairs(ReplicatedStorage:GetDescendants()) do
        if obj:IsA("RemoteEvent") and obj.Name:lower():find("missile") then
            return obj
        end
    end
    return nil
end

local SpawnRemote = findRemote({"SpawnMissile", "BuyMissile", "PurchaseMissile", "SpawnRocket"})
local LaunchRemote = findRemote({"LaunchMissile", "FireMissile", "LaunchRocket"})

local function hasMissile()
    local ls = player:FindFirstChild("leaderstats")
    if ls then
        for _, stat in ipairs(ls:GetChildren()) do
            local n = stat.Name:lower()
            if n:find("coin") or n:find("cash") or n:find("money") then
                if stat.Value < 1000 then return false end
            end
        end
    end
    for _, bag in ipairs({player.Backpack, player.Character}) do
        if bag then
            for _, it in ipairs(bag:GetChildren()) do
                if it.Name:lower():find("missile") then return true end
            end
        end
    end
    return true
end

local function findActiveMissile()
    local best = nil
    local bestScore = -math.huge
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") or obj:IsA("Model") then
            local n = obj.Name:lower()
            if n:find("missile") or n:find("rocket") then
                local root = obj:IsA("Model") and obj.PrimaryPart or obj
                if root then
                    local dist = player.Character and player.Character.PrimaryPart
                        and (root.Position - player.Character.PrimaryPart.Position).Magnitude or 0
                    local score = -dist + root.Position.Y
                    if score > bestScore then
                        bestScore = score
                        best = obj
                    end
                end
            end
        end
    end
    return best
end

